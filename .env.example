# Скопируйте этот файл в .env и заполните значения
# НЕ добавляйте .env в git (он уже в .gitignore)

# Токен бота — получить у @BotFather
BOT_TOKEN=ваш_токен_здесь

# Ключ погоды — бесплатно на openweathermap.org
WEATHER_API_KEY=ваш_ключ_здесь

# Ваш Telegram ID — узнать у @userinfobot
ADMIN_ID=ваш_id_здесь

# Groq API ключ — получить на console.groq.com (бесплатно)
# Нужен для ИИ "Кожаный Мешок" в групповых чатах
GROQ_API_KEY=ваш_groq_ключ_здесь
