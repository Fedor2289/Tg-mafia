BOT_TOKEN=ваш_токен_здесь
WEATHER_API_KEY=ваш_ключ_openweathermap
ADMIN_ID=ваш_telegram_id

# ИИ — выбери один или оба (бот возьмёт первый рабочий)
GROQ_API_KEY=ваш_groq_ключ          # console.groq.com (бесплатно)
CEREBRAS_API_KEY=ваш_cerebras_ключ   # cloud.cerebras.ai (бесплатно)

# Какой бэкенд использовать: groq | cerebras | auto (по умолчанию auto)
AI_BACKEND=auto
